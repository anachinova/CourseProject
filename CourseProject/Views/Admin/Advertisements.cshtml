@model List<CourseProject.Domain.Models.Advertisement>

@{
    ViewData["Title"] = "Керування оголошеннями";
}

<section class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Керування оголошеннями</h1>
            <p class="text-muted mb-0">Адміністратор може переглядати та видаляти будь-які оголошення.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-controller="Admin" asp-action="Index">
            Назад
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (Model == null || !Model.Any())
            {
                <div class="p-4 text-muted">Оголошень поки немає.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Фото</th>
                                <th>Назва</th>
                                <th>Автор</th>
                                <th>Категорія</th>
                                <th>Місто</th>
                                <th>Ціна</th>
                                <th>Дата</th>
                                <th class="text-end">Дії</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ad in Model)
                            {
                                var firstImage = ad.Images != null && ad.Images.Any()
                                    ? ad.Images.First().Path
                                    : "/images/ad-phone.jpg";

                                <tr>
                                    <td style="width: 80px;">
                                        <img src="@firstImage"
                                             alt="@ad.Title"
                                             class="rounded"
                                             style="width: 64px; height: 48px; object-fit: cover;" />
                                    </td>
                                    <td>@ad.Title</td>
                                    <td>@(ad.Author?.Username ?? "Невідомо")</td>
                                    <td>@(ad.Category?.Name ?? "Без категорії")</td>
                                    <td>@ad.City</td>
                                    <td>@ad.Price грн</td>
                                    <td>@ad.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-controller="Advertisements"
                                               asp-action="Details"
                                               asp-route-id="@ad.Id">
                                                Перегляд
                                            </a>

                                            <form asp-controller="Admin"
                                                  asp-action="DeleteAdvertisement"
                                                  asp-route-id="@ad.Id"
                                                  method="post"
                                                  onsubmit="return confirm('Видалити це оголошення?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    Видалити
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>
