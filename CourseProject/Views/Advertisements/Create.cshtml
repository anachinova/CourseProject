@model CourseProject.ViewModels.AdvertisementCreateViewModel

@{
    ViewData["Title"] = "Створення оголошення";
}

<div class="container">
    <div class="form-card">
        <h1>Створення оголошення</h1>
        <p>Заповніть інформацію про товар або послугу.</p>

        <form asp-controller="Advertisements"
              asp-action="Create"
              method="post"
              enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Title" class="form-label">Назва оголошення</label>
                <input asp-for="Title" type="text" class="form-control" placeholder="Наприклад: Смартфон Samsung Galaxy" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Опис</label>
                <textarea asp-for="Description" class="form-control" rows="5" placeholder="Опишіть товар або послугу"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Price" class="form-label">Ціна, грн</label>
                    <input asp-for="Price" type="number" class="form-control" placeholder="8500" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="City" class="form-label">Місто</label>
                    <input asp-for="City" type="text" class="form-control" placeholder="Харків" />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Категорія</label>
                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                    <option value="">Оберіть категорію</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Images" class="form-label">Зображення</label>
                <input asp-for="Images"
                       type="file"
                       class="form-control"
                       accept="image/*"
                       multiple />

                <small class="text-muted">
                    Можна завантажити до 10 фотографій.
                </small>

                <span asp-validation-for="Images" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <a class="btn btn-outline-secondary" asp-controller="Advertisements" asp-action="My">
                    Скасувати
                </a>

                <button type="submit" class="btn btn-success">
                    Опублікувати
                </button>
            </div>
        </form>
    </div>
</div>